PIPELINE_ENV=dev
PIPELINE_STORAGE_MODE=local
PIPELINE_SCALE_FACTOR=12
PIPELINE_RAW_SOURCE_PATH=/opt/airflow/data/raw/ecommerce_sales.csv
PIPELINE_OUTPUT_ROOT=/opt/airflow/data/processed
PIPELINE_S3_BUCKET=
PIPELINE_S3_PREFIX=ecommerce-analytics
PIPELINE_AWS_REGION=us-east-1
PIPELINE_POSTGRES_HOST=postgres
PIPELINE_POSTGRES_PORT=5432
PIPELINE_POSTGRES_DB=analytics
PIPELINE_POSTGRES_USER=airflow
PIPELINE_POSTGRES_PASSWORD=airflow
AIRFLOW_UID=50000
_PIP_ADDITIONAL_REQUIREMENTS=
